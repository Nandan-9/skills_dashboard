# Copy this file to deploy/.env on the server and fill in real secrets.
# deploy/.env is gitignored and must never be committed.

# --- Postgres (used by the db service, and mirrored into DB_* below) ---
POSTGRES_DB=skills
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# --- Django backend ---
SECRET_KEY=change-me
DEBUG=False
# "backend" must stay in this list - the frontend container calls Django
# using that internal docker hostname over the compose network.
ALLOWED_HOSTS=localhost,127.0.0.1,backend,your-domain-or-server-ip

DB_NAME=skills
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432

GOOGLE_SERVICE_ACCOUNT_FILE=gcp_service_account.json
GOOGLE_SHEET_ID=
GOOGLE_SHEET_WORKSHEET=
GOOGLE_SHEET_WORKSHEET2=
SHEET_SYNC_API_KEY=change-me
GOOGLE_DRIVE_PARENT_FOLDER_ID=
